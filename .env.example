# ══════════════════════════════════════════════
# BACKEND (.env in project root)
# ══════════════════════════════════════════════

# Required API Keys
CEREBRAS_API_KEY=your_cerebras_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional API Keys
GOOGLE_PLACES_API_KEY=        # Enables competitor review fallback

# Persistence
SYLON_DB_PATH=data/sylon.db

# Tuning
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
GEMINI_MODEL=gemini-2.0-flash-exp
SYLON_PERSONA_COUNT=2
SYLON_DEBUG_MODE=False

# ══════════════════════════════════════════════
# FRONTEND (frontend/.env.local)
# ══════════════════════════════════════════════

# ElevenLabs Voice Agent (optional — orb still renders without it)
# NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id

# Backend URL override (default: http://localhost:8000)
# SYLON_API_URL=http://localhost:8000
